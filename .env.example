# Next.js
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Sanity CMS (Story 1.3+)
# Get these from https://sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=your_api_token

# Supabase Database (Future Stories)
# Get these from https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Upstash Redis (Future Stories)
# Get these from https://console.upstash.com
UPSTASH_REDIS_REST_URL=your_redis_url
UPSTASH_REDIS_REST_TOKEN=your_redis_token

# Email Service - Resend (Future Stories)
# Get this from https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key

# Analytics (Story 1.7)
# Get this from https://analytics.google.com
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Sentry Error Tracking (Future Stories)
# Get these from https://sentry.io
SENTRY_DSN=your_sentry_dsn
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn

# Microsoft Clarity (Future Stories)
# Get this from https://clarity.microsoft.com
NEXT_PUBLIC_CLARITY_PROJECT_ID=your_clarity_id
